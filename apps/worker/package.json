{
  "name": "@accevum/worker",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build -w @accevum/db && ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build -w @accevum/db && node dist/index.js",
    "typecheck": "tsc --pretty --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@accevum/db": "1.0.0",
    "bullmq": "^5.8.0",
    "ioredis": "^5.4.1",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "ts-node": "^10.9.2"
  }
}
