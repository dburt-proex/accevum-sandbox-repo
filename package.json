{
  "name": "accevum-service",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready TypeScript Fastify microservice",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
