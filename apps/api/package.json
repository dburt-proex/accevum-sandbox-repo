{
  "name": "@accevum/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build -w @accevum/db && ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build -w @accevum/db && node dist/server.js",
    "typecheck": "npm run build -w @accevum/db && tsc --pretty --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@accevum/db": "1.0.0",
    "@fastify/jwt": "^10.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.51.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.8.4",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.3.0",
    "ts-node": "^10.9.2"
  }
}
